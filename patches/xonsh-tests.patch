+  stdenv,
   buildPythonPackage,
   fetchFromGitHub,
 
@@ -63,7 +64,8 @@ buildPythonPackage rec {
     pytest-subprocess
     pytestCheckHook
     requests
-
+  ]
+  ++ lib.optionals (!stdenv.isDarwin) [
     # required by test_man_completion
     man
     util-linux
